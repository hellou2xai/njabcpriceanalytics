# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-your-key-here
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
VITE_API_URL=http://localhost:8000
PARQUET_DIR=parquet_output
DATA_DIR=Data
DUCKDB_PATH=:memory:
# PostgreSQL user-data store. Render injects DATABASE_URL in production; for
# local dev create a database and point here, e.g.:
DATABASE_URL=postgresql://celr:celrdev@localhost:5432/celr_dev
# Google Places API (New) key for store name -> address lookup.
# Enable "Places API (New)" in Google Cloud and restrict the key. Leave blank
# to disable lookup and fall back to manual address entry.
GOOGLE_MAPS_API_KEY=
